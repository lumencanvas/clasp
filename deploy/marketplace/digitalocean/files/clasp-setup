#!/usr/bin/env bash
set -euo pipefail

# CLASP Relay -- Interactive Setup
# Generates docker-compose.yml and Caddyfile, then starts services.
# Re-run at any time to reconfigure.

CLASP_DIR="/opt/clasp"
DATA_DIR="/var/lib/clasp"
CERT_DIR="${DATA_DIR}/certs"
COMPOSE_FILE="${CLASP_DIR}/docker-compose.yml"
CADDY_FILE="${CLASP_DIR}/Caddyfile"
TOKEN_FILE="${DATA_DIR}/admin.token"

# ---------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------

banner() {
  echo ""
  echo "  ================================================================"
  echo "   CLASP Relay Setup"
  echo "   Real-time infrastructure for connected devices"
  echo "  ================================================================"
  echo ""
}

section() {
  echo ""
  echo "  ---- $1 ----"
  echo ""
}

info() {
  echo "  $1"
}

ask() {
  local prompt="$1" default="${2:-}" value
  if [ -n "$default" ]; then
    read -rp "  ${prompt} [${default}]: " value
    echo "${value:-$default}"
  else
    while [ -z "${value:-}" ]; do
      read -rp "  ${prompt}: " value
    done
    echo "$value"
  fi
}

ask_yn() {
  local prompt="$1" default="${2:-n}" value
  read -rp "  ${prompt} [${default}]: " value
  value="${value:-$default}"
  [[ "$value" =~ ^[Yy] ]]
}

ask_choice() {
  local prompt="$1" options="$2" default="$3" value
  read -rp "  ${prompt} (${options}) [${default}]: " value
  echo "${value:-$default}"
}

gen_token() {
  openssl rand -base64 32 | tr -d '/+=' | head -c 32
}

add_flag() {
  CMD_ARGS+="      - \"$1\"\n      - \"$2\"\n"
}

add_bare_flag() {
  CMD_ARGS+="      - \"$1\"\n"
}

# ---------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------

if [ "$(id -u)" -ne 0 ]; then
  echo "Error: run as root (sudo clasp-setup)"
  exit 1
fi

if ! command -v docker &>/dev/null; then
  echo "Error: docker not found."
  echo "Run the bootstrap script first:"
  echo "  curl -fsSL https://raw.githubusercontent.com/lumencanvas/clasp/main/deploy/marketplace/digitalocean/bootstrap.sh | bash"
  exit 1
fi

banner

# Stop existing deployment if running
if [ -f "$COMPOSE_FILE" ]; then
  info "Existing configuration detected."
  if ! ask_yn "Reconfigure and restart? (y/n)" "y"; then
    echo "  Aborted."
    exit 0
  fi
  echo ""
  docker compose -f "$COMPOSE_FILE" down 2>/dev/null || true
fi

# ---------------------------------------------------------------
# Profile selection
# ---------------------------------------------------------------

echo "  What kind of deployment do you need?"
echo ""
echo "    [1] Standard"
echo "        WebSocket + TLS + authentication + state persistence."
echo "        Good for: web apps, dashboards, chat, collaboration tools."
echo ""
echo "    [2] Full"
echo "        Everything in Standard, plus MQTT and OSC protocol bridges,"
echo "        SQLite journal, rules engine, entity registry, capability"
echo "        tokens, and Prometheus metrics."
echo "        Good for: IoT, smart buildings, live performance, production."
echo ""
echo "    [3] IoT / Sensors"
echo "        Standard + MQTT bridge + rules engine + journal."
echo "        Good for: sensor networks, device monitoring, automation."
echo ""
echo "    [4] Creative / Live"
echo "        Standard + OSC bridge + MQTT bridge + low TTLs."
echo "        Good for: lighting rigs, VJ software, stage control."
echo ""
echo "    [5] Minimal"
echo "        WebSocket only. No TLS, no auth, no persistence."
echo "        Good for: local development, testing behind another proxy."
echo ""

PROFILE=$(ask "Profile" "1")
case "$PROFILE" in
  1) PROFILE_NAME="standard" ;;
  2) PROFILE_NAME="full" ;;
  3) PROFILE_NAME="iot" ;;
  4) PROFILE_NAME="creative" ;;
  5) PROFILE_NAME="minimal" ;;
  *) PROFILE_NAME="standard" ;;
esac

# ---------------------------------------------------------------
# Set defaults
# ---------------------------------------------------------------

WS_PORT="7330"
HOST="0.0.0.0"
RELAY_NAME=""
NO_WEBSOCKET=false

ENABLE_TLS=true
DOMAIN=""
ACME_EMAIL=""

ENABLE_AUTH=true
AUTH_PORT="7350"
AUTH_DB="/data/auth.db"
CORS_ORIGINS=""
ADMIN_TOKEN=""
TOKEN_TTL="86400"

ENABLE_QUIC=false
QUIC_PORT="4433"
QUIC_CERT=""
QUIC_KEY=""

ENABLE_MQTT=false
MQTT_PORT="1883"
MQTT_NAMESPACE="/mqtt"

ENABLE_OSC=false
OSC_PORT="8000"
OSC_NAMESPACE="/osc"

MAX_SESSIONS="1000"
SESSION_TIMEOUT="300"

PARAM_TTL="3600"
SIGNAL_TTL="3600"
NO_TTL=false

ENABLE_PERSIST=true
PERSIST_PATH="/data/state.json"
PERSIST_INTERVAL="30"

ENABLE_JOURNAL=false
JOURNAL_BACKEND="sqlite"
JOURNAL_PATH="/data/journal.db"
JOURNAL_MEMORY=false
DEFRA_URL=""

ENABLE_CAP_TOKENS=false
TRUST_ANCHOR=""
CAP_MAX_DEPTH="5"

ENABLE_REGISTRY=false
REGISTRY_DB="/data/registry.db"

ENABLE_RULES=false
RULES_PATH="/data/rules.json"

ENABLE_APP_CONFIG=false
APP_CONFIG_PATH="/data/app-config.json"

ENABLE_LENSES=false
LENSES_PATH="/data/lenses.json"

ENABLE_FEDERATION=false
FEDERATION_HUB=""
FEDERATION_ID=""
FEDERATION_NAMESPACE=""
FEDERATION_TOKEN=""

ENABLE_METRICS=false
METRICS_PORT="9090"

ENABLE_HEALTH=true
HEALTH_PORT="7360"
DRAIN_TIMEOUT="30"

RENDEZVOUS_PORT="7340"
RENDEZVOUS_TTL="300"

VERBOSE=false

# Apply profile overrides
case "$PROFILE_NAME" in
  full)
    ENABLE_MQTT=true
    ENABLE_OSC=true
    ENABLE_JOURNAL=true
    ENABLE_RULES=true
    ENABLE_METRICS=true
    ENABLE_REGISTRY=true
    ENABLE_CAP_TOKENS=true
    ;;
  iot)
    ENABLE_MQTT=true
    ENABLE_JOURNAL=true
    ENABLE_RULES=true
    ;;
  creative)
    ENABLE_MQTT=true
    ENABLE_OSC=true
    PARAM_TTL="300"
    SIGNAL_TTL="60"
    ;;
  minimal)
    ENABLE_TLS=false
    ENABLE_AUTH=false
    ENABLE_PERSIST=false
    ENABLE_HEALTH=false
    NO_TTL=true
    ;;
esac

# ---------------------------------------------------------------
# 1. Domain and TLS
# ---------------------------------------------------------------

section "Domain and TLS"

if [ "$ENABLE_TLS" = true ]; then
  info "TLS provides encrypted connections via Let's Encrypt."
  info "You need a domain name pointed at this server's IP address."
  echo ""
  DOMAIN=$(ask "Domain name (e.g. relay.example.com)")
  ACME_EMAIL=$(ask "Email for Let's Encrypt certificates")
  echo ""
  info "Make sure the DNS A record for ${DOMAIN} points to this server."
else
  DOMAIN=$(hostname -I | awk '{print $1}')
  info "TLS is disabled. Relay will listen on http://${DOMAIN}"
  echo ""
  if ask_yn "Enable TLS? (requires a domain name) (y/n)" "n"; then
    ENABLE_TLS=true
    DOMAIN=$(ask "Domain name (e.g. relay.example.com)")
    ACME_EMAIL=$(ask "Email for Let's Encrypt certificates")
  fi
fi

RELAY_NAME=$(ask "Server name (shown to connecting clients)" "$DOMAIN")

# ---------------------------------------------------------------
# 2. Authentication
# ---------------------------------------------------------------

section "Authentication"

if [ "$ENABLE_AUTH" = true ]; then
  info "Authentication controls who can connect and what they can do."
  info "Clients register or login to get a token. The relay validates"
  info "tokens on every message and enforces address-level scopes."
  echo ""
  info "Without auth, anyone who can reach the relay can read/write"
  info "any address. Fine for local dev, not for production."
  echo ""
  TOKEN_TTL=$(ask "Token TTL in seconds (how long tokens last, 0 = forever)" "$TOKEN_TTL")
else
  info "Authentication is disabled."
  echo ""
  if ask_yn "Enable authentication? (y/n)" "n"; then
    ENABLE_AUTH=true
    TOKEN_TTL=$(ask "Token TTL in seconds (0 = forever)" "$TOKEN_TTL")
  fi
fi

if [ "$ENABLE_TLS" = true ] && [ "$ENABLE_AUTH" = true ]; then
  echo ""
  info "CORS controls which web origins can call the auth API."
  info "Comma-separated. Example: https://myapp.com,https://clasp.chat"
  CORS_ORIGINS=$(ask "Allowed CORS origins" "https://${DOMAIN}")
fi

# ---------------------------------------------------------------
# 3. Protocol bridges
# ---------------------------------------------------------------

section "Protocol Bridges"

info "Bridges let non-CLASP devices connect through the relay."
info "MQTT: IoT sensors, home automation, message brokers."
info "OSC: TouchOSC, lighting controllers, VJ software, DAWs."
echo ""

if [ "$ENABLE_MQTT" = false ]; then
  ask_yn "Enable MQTT bridge? (y/n)" "n" && ENABLE_MQTT=true
fi
if [ "$ENABLE_OSC" = false ]; then
  ask_yn "Enable OSC bridge? (y/n)" "n" && ENABLE_OSC=true
fi

if [ "$ENABLE_MQTT" = true ]; then
  echo ""
  MQTT_PORT=$(ask "MQTT listen port" "$MQTT_PORT")
  MQTT_NAMESPACE=$(ask "MQTT namespace prefix (MQTT topics appear under this path)" "$MQTT_NAMESPACE")
fi

if [ "$ENABLE_OSC" = true ]; then
  echo ""
  OSC_PORT=$(ask "OSC listen port (UDP)" "$OSC_PORT")
  OSC_NAMESPACE=$(ask "OSC namespace prefix (OSC addresses appear under this path)" "$OSC_NAMESPACE")
fi

# ---------------------------------------------------------------
# 4. Persistence and journal
# ---------------------------------------------------------------

section "State Persistence"

info "CLASP state is in-memory by default. Two options to survive restarts:"
echo ""
info "  Snapshots  Periodic dump of all current parameter values to disk."
info "             Fast, simple. You get the latest state on restart."
info "             No history, no replay, no point-in-time recovery."
echo ""
info "  Journal    Ordered log of every state change. Enables replay,"
info "             crash recovery, and time-travel queries. Heavier but"
info "             gives you a complete audit trail."
echo ""
info "  You can use both. Snapshots for fast startup, journal for history."
echo ""

if [ "$ENABLE_PERSIST" = true ]; then
  info "Snapshots: enabled (default for this profile)."
  PERSIST_INTERVAL=$(ask "Snapshot interval in seconds" "$PERSIST_INTERVAL")
else
  if ask_yn "Enable state snapshots? (y/n)" "y"; then
    ENABLE_PERSIST=true
    PERSIST_INTERVAL=$(ask "Snapshot interval in seconds" "30")
  fi
fi

echo ""
if [ "$ENABLE_JOURNAL" = false ]; then
  if ask_yn "Enable journal (event log)? (y/n)" "n"; then
    ENABLE_JOURNAL=true
  fi
fi

if [ "$ENABLE_JOURNAL" = true ]; then
  echo ""
  info "Journal backends:"
  info "  sqlite  Local file. Single-node. Fast. Good for most deployments."
  info "  defra   DefraDB (Merkle CRDTs). Multi-node P2P sync. State"
  info "          replicates between nodes automatically. Requires a"
  info "          DefraDB instance (will be started as a Docker container)."
  echo ""
  JOURNAL_BACKEND=$(ask_choice "Journal backend" "sqlite/defra" "$JOURNAL_BACKEND")

  case "$JOURNAL_BACKEND" in
    defra)
      info ""
      info "A DefraDB container will be added to the deployment."
      DEFRA_URL=$(ask "DefraDB endpoint (inside Docker network)" "http://defra:9181/api/v0/graphql")
      ;;
    sqlite|*)
      JOURNAL_BACKEND="sqlite"
      JOURNAL_PATH=$(ask "Journal database path (inside container)" "$JOURNAL_PATH")
      ;;
  esac
fi

# ---------------------------------------------------------------
# 5. Security features
# ---------------------------------------------------------------

if [ "$ENABLE_AUTH" = true ]; then
  section "Security Features"

  info "These build on top of basic auth with more fine-grained control."
  echo ""

  # Capability tokens
  if [ "$ENABLE_CAP_TOKENS" = false ]; then
    info "Capability tokens: Ed25519 signed tokens with delegation chains."
    info "A root key can issue tokens that grant access to specific address"
    info "patterns. Those tokens can delegate narrower access to others."
    info "Useful when you have devices or services that need scoped access"
    info "without going through the auth API."
    echo ""
    if ask_yn "Enable capability tokens? (y/n)" "n"; then
      ENABLE_CAP_TOKENS=true
    fi
  fi

  if [ "$ENABLE_CAP_TOKENS" = true ]; then
    echo ""
    info "Trust anchors are Ed25519 public keys that the relay trusts as"
    info "root issuers. Generate one with: clasp key generate --out root.key"
    TRUST_ANCHOR=$(ask "Trust anchor key file path (blank to skip)" "")
    CAP_MAX_DEPTH=$(ask "Max delegation chain depth" "$CAP_MAX_DEPTH")
  fi

  echo ""

  # Entity registry
  if [ "$ENABLE_REGISTRY" = false ]; then
    info "Entity registry: persistent identity store for devices, users,"
    info "and services. Each entity gets a signed Ed25519 token. The relay"
    info "tracks entity status (active, suspended, revoked) and exposes"
    info "a REST API for management."
    echo ""
    if ask_yn "Enable entity registry? (y/n)" "n"; then
      ENABLE_REGISTRY=true
    fi
  fi

  if [ "$ENABLE_REGISTRY" = true ]; then
    REGISTRY_DB=$(ask "Registry database path (inside container)" "$REGISTRY_DB")
  fi
fi

# ---------------------------------------------------------------
# 6. Automation
# ---------------------------------------------------------------

section "Automation"

info "Server-side logic that runs on the relay without client code."
echo ""

# Rules engine
if [ "$ENABLE_RULES" = false ]; then
  info "Rules engine: reactive triggers that fire on state changes."
  info "Example: when /sensors/temp exceeds 30, set /hvac/fan to true."
  info "Supports thresholds, pattern matching, cooldowns, transforms."
  info "Rules are defined in a JSON file."
  echo ""
  if ask_yn "Enable rules engine? (y/n)" "n"; then
    ENABLE_RULES=true
  fi
else
  info "Rules engine: enabled (default for this profile)."
fi

if [ "$ENABLE_RULES" = true ]; then
  RULES_PATH=$(ask "Rules JSON file path (inside container)" "$RULES_PATH")
fi

echo ""

# LensVM
info "LensVM: programmable signal transforms via WebAssembly."
info "Load WASM modules that process values in the relay's hot path."
info "Example: lowpass filter on sensor data, hysteresis for debouncing."
info "Lenses are defined in a JSON config that maps address patterns"
info "to WASM files and parameters."
echo ""
if ask_yn "Enable LensVM transforms? (y/n)" "n"; then
  ENABLE_LENSES=true
  LENSES_PATH=$(ask "Lenses JSON file path (inside container)" "$LENSES_PATH")
fi

echo ""

# App config
info "App config: scopes, write rules, and snapshot visibility rules."
info "Scopes template which addresses each user can access."
info "Write rules validate values before they're stored (e.g. 'only the"
info "room creator can set /room/*/admin'). Snapshot rules control what"
info "data clients see when they connect."
echo ""
if ask_yn "Load app config? (y/n)" "n"; then
  ENABLE_APP_CONFIG=true
  APP_CONFIG_PATH=$(ask "App config JSON file path (inside container)" "$APP_CONFIG_PATH")
fi

# ---------------------------------------------------------------
# 7. Federation
# ---------------------------------------------------------------

section "Federation"

info "Federation connects multiple CLASP relays into a coordinated"
info "network. Each relay owns a namespace prefix (e.g. /building-a/**)."
info "A hub relay aggregates state from all connected leaves."
echo ""
info "Use this when you have multiple physical sites that need to share"
info "state, or when you want to scale horizontally across regions."
echo ""

if ask_yn "Enable federation? (y/n)" "n"; then
  ENABLE_FEDERATION=true
  echo ""
  FEDERATION_HUB=$(ask "Hub relay WebSocket URL (e.g. ws://hub.example.com:7330)")
  FEDERATION_ID=$(ask "This relay's identity (unique name)" "$(hostname -s)")
  echo ""
  info "Namespace: the address prefix this relay owns. Writes to addresses"
  info "under this prefix originate here and propagate to the hub."
  FEDERATION_NAMESPACE=$(ask "Owned namespace pattern (e.g. /site-a/**)" "")
  FEDERATION_TOKEN=$(ask "Auth token for hub (blank if open)" "")
fi

# ---------------------------------------------------------------
# 8. Advanced settings
# ---------------------------------------------------------------

echo ""
if ask_yn "Configure advanced settings (TTLs, sessions, QUIC, metrics)? (y/n)" "n"; then

  section "Sessions"
  info "Max sessions limits concurrent WebSocket connections."
  info "Session timeout disconnects idle clients."
  MAX_SESSIONS=$(ask "Max sessions (0 = unlimited)" "$MAX_SESSIONS")
  SESSION_TIMEOUT=$(ask "Session timeout in seconds" "$SESSION_TIMEOUT")

  section "TTL (Time-To-Live)"
  info "TTLs automatically remove stale parameters and signal definitions."
  info "Param TTL: how long a parameter persists without being updated."
  info "Signal TTL: how long a signal definition persists without access."
  info "Set to 0 to disable individual TTLs. Or disable all TTLs to"
  info "keep everything forever (higher memory usage)."
  echo ""
  if [ "$NO_TTL" = true ]; then
    info "TTLs are currently disabled."
    if ask_yn "Enable TTLs? (y/n)" "n"; then
      NO_TTL=false
      PARAM_TTL=$(ask "Parameter TTL in seconds" "3600")
      SIGNAL_TTL=$(ask "Signal TTL in seconds" "3600")
    fi
  else
    PARAM_TTL=$(ask "Parameter TTL in seconds (0 = disabled)" "$PARAM_TTL")
    SIGNAL_TTL=$(ask "Signal TTL in seconds (0 = disabled)" "$SIGNAL_TTL")
    if ask_yn "Disable all TTLs (keep everything forever)? (y/n)" "n"; then
      NO_TTL=true
    fi
  fi

  section "QUIC Transport"
  info "QUIC provides multiplexed streams with built-in TLS and 0-RTT"
  info "reconnection. Faster than WebSocket for native applications."
  info "Requires a TLS certificate and private key."
  echo ""
  if ask_yn "Enable QUIC transport? (y/n)" "n"; then
    ENABLE_QUIC=true
    QUIC_PORT=$(ask "QUIC listen port (UDP)" "$QUIC_PORT")
    QUIC_CERT=$(ask "TLS certificate path (inside container)" "/data/certs/cert.pem")
    QUIC_KEY=$(ask "TLS private key path (inside container)" "/data/certs/key.pem")
    echo ""
    info "Place your cert and key files in ${CERT_DIR}/ on the host."
  fi

  section "Health and Metrics"
  if [ "$ENABLE_HEALTH" = false ]; then
    if ask_yn "Enable health check endpoints (/healthz, /readyz)? (y/n)" "y"; then
      ENABLE_HEALTH=true
      HEALTH_PORT=$(ask "Health check port" "$HEALTH_PORT")
    fi
  else
    HEALTH_PORT=$(ask "Health check port" "$HEALTH_PORT")
  fi
  DRAIN_TIMEOUT=$(ask "Graceful shutdown drain timeout in seconds" "$DRAIN_TIMEOUT")

  echo ""
  if [ "$ENABLE_METRICS" = false ]; then
    info "Prometheus metrics expose request counts, latencies, and fanout"
    info "histograms at /metrics for monitoring and alerting."
    echo ""
    if ask_yn "Enable Prometheus metrics? (y/n)" "n"; then
      ENABLE_METRICS=true
      METRICS_PORT=$(ask "Metrics port" "$METRICS_PORT")
    fi
  else
    METRICS_PORT=$(ask "Metrics port" "$METRICS_PORT")
  fi

  section "Discovery"
  info "Rendezvous server allows devices to discover this relay on WAN."
  RENDEZVOUS_PORT=$(ask "Rendezvous port (0 = disabled)" "$RENDEZVOUS_PORT")
  RENDEZVOUS_TTL=$(ask "Device registration TTL in seconds" "$RENDEZVOUS_TTL")

  section "Ports"
  WS_PORT=$(ask "WebSocket port" "$WS_PORT")
  if ask_yn "Disable WebSocket (use QUIC/MQTT/OSC only)? (y/n)" "n"; then
    NO_WEBSOCKET=true
  fi

  section "Logging"
  if ask_yn "Enable verbose/debug logging? (y/n)" "n"; then
    VERBOSE=true
  fi
fi

# ---------------------------------------------------------------
# Generate admin token
# ---------------------------------------------------------------

mkdir -p "$DATA_DIR"
mkdir -p "$CERT_DIR"

if [ "$ENABLE_AUTH" = true ]; then
  if [ -f "$TOKEN_FILE" ]; then
    ADMIN_TOKEN=$(cat "$TOKEN_FILE")
    echo ""
    info "Using existing admin token from ${TOKEN_FILE}"
  else
    ADMIN_TOKEN=$(gen_token)
    echo "$ADMIN_TOKEN" > "$TOKEN_FILE"
    chmod 600 "$TOKEN_FILE"
  fi
fi

# Create empty config files if needed
if [ "$ENABLE_RULES" = true ] && [ ! -f "${DATA_DIR}/rules.json" ]; then
  echo '[]' > "${DATA_DIR}/rules.json"
  info "Created empty rules file: ${DATA_DIR}/rules.json"
fi

if [ "$ENABLE_LENSES" = true ] && [ ! -f "${DATA_DIR}/lenses.json" ]; then
  echo '[]' > "${DATA_DIR}/lenses.json"
  info "Created empty lenses file: ${DATA_DIR}/lenses.json"
fi

if [ "$ENABLE_APP_CONFIG" = true ] && [ ! -f "${DATA_DIR}/app-config.json" ]; then
  cat > "${DATA_DIR}/app-config.json" <<'JSON'
{
  "scopes": [],
  "write_rules": [],
  "snapshot_transforms": [],
  "snapshot_visibility": []
}
JSON
  info "Created empty app config: ${DATA_DIR}/app-config.json"
fi

# ---------------------------------------------------------------
# Build relay command arguments
# ---------------------------------------------------------------

section "Generating Configuration"

CMD_ARGS=""

add_flag "--ws-port" "$WS_PORT"
add_flag "--host" "$HOST"
add_flag "--name" "$RELAY_NAME"

[ "$NO_WEBSOCKET" = true ] && add_bare_flag "--no-websocket"

if [ "$ENABLE_HEALTH" = true ]; then
  add_flag "--health-port" "$HEALTH_PORT"
  add_flag "--drain-timeout" "$DRAIN_TIMEOUT"
fi

if [ "$ENABLE_AUTH" = true ]; then
  add_flag "--auth-port" "$AUTH_PORT"
  add_flag "--auth-db" "$AUTH_DB"
  add_flag "--admin-token" "/data/admin.token"
  add_flag "--token-ttl" "$TOKEN_TTL"
fi

[ -n "$CORS_ORIGINS" ] && add_flag "--cors-origin" "$CORS_ORIGINS"

if [ "$ENABLE_QUIC" = true ]; then
  add_flag "--quic-port" "$QUIC_PORT"
  add_flag "--cert" "$QUIC_CERT"
  add_flag "--key" "$QUIC_KEY"
fi

if [ "$ENABLE_MQTT" = true ]; then
  add_flag "--mqtt-port" "$MQTT_PORT"
  add_flag "--mqtt-namespace" "$MQTT_NAMESPACE"
fi

if [ "$ENABLE_OSC" = true ]; then
  add_flag "--osc-port" "$OSC_PORT"
  add_flag "--osc-namespace" "$OSC_NAMESPACE"
fi

add_flag "--max-sessions" "$MAX_SESSIONS"
add_flag "--session-timeout" "$SESSION_TIMEOUT"

if [ "$NO_TTL" = true ]; then
  add_bare_flag "--no-ttl"
else
  add_flag "--param-ttl" "$PARAM_TTL"
  add_flag "--signal-ttl" "$SIGNAL_TTL"
fi

if [ "$ENABLE_PERSIST" = true ]; then
  add_flag "--persist" "$PERSIST_PATH"
  add_flag "--persist-interval" "$PERSIST_INTERVAL"
fi

if [ "$ENABLE_JOURNAL" = true ]; then
  add_flag "--journal-backend" "$JOURNAL_BACKEND"
  case "$JOURNAL_BACKEND" in
    defra) add_flag "--defra-url" "$DEFRA_URL" ;;
    sqlite) add_flag "--journal" "$JOURNAL_PATH" ;;
  esac
  [ "$JOURNAL_MEMORY" = true ] && add_bare_flag "--journal-memory"
fi

if [ "$ENABLE_CAP_TOKENS" = true ]; then
  [ -n "$TRUST_ANCHOR" ] && add_flag "--trust-anchor" "$TRUST_ANCHOR"
  add_flag "--cap-max-depth" "$CAP_MAX_DEPTH"
fi

[ "$ENABLE_REGISTRY" = true ] && add_flag "--registry-db" "$REGISTRY_DB"
[ "$ENABLE_RULES" = true ] && add_flag "--rules" "$RULES_PATH"
[ "$ENABLE_APP_CONFIG" = true ] && add_flag "--app-config" "$APP_CONFIG_PATH"
[ "$ENABLE_LENSES" = true ] && add_flag "--lenses" "$LENSES_PATH"

if [ "$ENABLE_FEDERATION" = true ]; then
  add_flag "--federation-hub" "$FEDERATION_HUB"
  [ -n "$FEDERATION_ID" ] && add_flag "--federation-id" "$FEDERATION_ID"
  [ -n "$FEDERATION_NAMESPACE" ] && add_flag "--federation-namespace" "$FEDERATION_NAMESPACE"
  [ -n "$FEDERATION_TOKEN" ] && add_flag "--federation-token" "$FEDERATION_TOKEN"
fi

[ "$ENABLE_METRICS" = true ] && add_flag "--metrics-port" "$METRICS_PORT"

add_flag "--rendezvous-port" "$RENDEZVOUS_PORT"
add_flag "--rendezvous-ttl" "$RENDEZVOUS_TTL"

[ "$VERBOSE" = true ] && add_bare_flag "--verbose"

# ---------------------------------------------------------------
# Build exposed ports
# ---------------------------------------------------------------

EXTRA_PORTS=""
[ "$ENABLE_MQTT" = true ] && EXTRA_PORTS+="      - \"${MQTT_PORT}:${MQTT_PORT}\"\n"
[ "$ENABLE_OSC" = true ] && EXTRA_PORTS+="      - \"${OSC_PORT}:${OSC_PORT}/udp\"\n"
[ "$ENABLE_QUIC" = true ] && EXTRA_PORTS+="      - \"${QUIC_PORT}:${QUIC_PORT}/udp\"\n"
[ "$ENABLE_METRICS" = true ] && EXTRA_PORTS+="      - \"${METRICS_PORT}:${METRICS_PORT}\"\n"

# ---------------------------------------------------------------
# Generate docker-compose.yml
# ---------------------------------------------------------------

cat > "$COMPOSE_FILE" <<YAML
# CLASP Relay -- generated by clasp-setup
# Profile: ${PROFILE_NAME}
# Reconfigure: clasp-setup

services:
YAML

if [ "$ENABLE_TLS" = true ]; then
  cat >> "$COMPOSE_FILE" <<YAML
  caddy:
    image: caddy:2-alpine
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ${CADDY_FILE}:/etc/caddy/Caddyfile:ro
      - caddy-data:/data
      - caddy-config:/config
    depends_on:
      - relay
    restart: unless-stopped

YAML
fi

if [ "$ENABLE_JOURNAL" = true ] && [ "$JOURNAL_BACKEND" = "defra" ]; then
  cat >> "$COMPOSE_FILE" <<YAML
  defra:
    image: sourcenetwork/defradb:latest
    command: ["start", "--no-keyring", "--url", "0.0.0.0:9181"]
    volumes:
      - defra-data:/data
    restart: unless-stopped

YAML
fi

cat >> "$COMPOSE_FILE" <<YAML
  relay:
    image: ghcr.io/lumencanvas/clasp-relay:latest
YAML

if [ "$ENABLE_TLS" = true ]; then
  if [ -n "$EXTRA_PORTS" ]; then
    echo "    ports:" >> "$COMPOSE_FILE"
    echo -e "$EXTRA_PORTS" >> "$COMPOSE_FILE"
  fi
else
  echo "    ports:" >> "$COMPOSE_FILE"
  echo "      - \"${WS_PORT}:${WS_PORT}\"" >> "$COMPOSE_FILE"
  [ "$ENABLE_AUTH" = true ] && echo "      - \"${AUTH_PORT}:${AUTH_PORT}\"" >> "$COMPOSE_FILE"
  [ "$ENABLE_HEALTH" = true ] && echo "      - \"${HEALTH_PORT}:${HEALTH_PORT}\"" >> "$COMPOSE_FILE"
  [ -n "$EXTRA_PORTS" ] && echo -e "$EXTRA_PORTS" >> "$COMPOSE_FILE"
fi

if [ "$ENABLE_JOURNAL" = true ] && [ "$JOURNAL_BACKEND" = "defra" ]; then
  cat >> "$COMPOSE_FILE" <<YAML
    depends_on:
      - defra
YAML
fi

RUST_LOG="info"
[ "$VERBOSE" = true ] && RUST_LOG="debug"

cat >> "$COMPOSE_FILE" <<YAML
    environment:
      RUST_LOG: ${RUST_LOG}
      LOG_FORMAT: json
    command:
YAML

echo -e "$CMD_ARGS" >> "$COMPOSE_FILE"

cat >> "$COMPOSE_FILE" <<YAML
    volumes:
      - ${DATA_DIR}:/data
    restart: unless-stopped

YAML

NEED_VOLUMES=false
[ "$ENABLE_TLS" = true ] && NEED_VOLUMES=true
[ "$ENABLE_JOURNAL" = true ] && [ "$JOURNAL_BACKEND" = "defra" ] && NEED_VOLUMES=true

if [ "$NEED_VOLUMES" = true ]; then
  echo "volumes:" >> "$COMPOSE_FILE"
  if [ "$ENABLE_TLS" = true ]; then
    echo "  caddy-data:" >> "$COMPOSE_FILE"
    echo "  caddy-config:" >> "$COMPOSE_FILE"
  fi
  if [ "$ENABLE_JOURNAL" = true ] && [ "$JOURNAL_BACKEND" = "defra" ]; then
    echo "  defra-data:" >> "$COMPOSE_FILE"
  fi
fi

# ---------------------------------------------------------------
# Generate Caddyfile
# ---------------------------------------------------------------

if [ "$ENABLE_TLS" = true ]; then
  cat > "$CADDY_FILE" <<CADDY
{
	email ${ACME_EMAIL}
}

${DOMAIN} {
CADDY

  if [ "$ENABLE_AUTH" = true ]; then
    cat >> "$CADDY_FILE" <<CADDY
	handle /auth/* {
		reverse_proxy relay:${AUTH_PORT}
	}

CADDY
  fi

  if [ "$ENABLE_METRICS" = true ]; then
    cat >> "$CADDY_FILE" <<CADDY
	handle /metrics {
		reverse_proxy relay:${METRICS_PORT}
	}

CADDY
  fi

  if [ "$ENABLE_HEALTH" = true ]; then
    cat >> "$CADDY_FILE" <<CADDY
	handle {
		reverse_proxy relay:${WS_PORT} {
			health_uri /healthz
			health_port ${HEALTH_PORT}
			health_interval 10s
		}
	}
}
CADDY
  else
    cat >> "$CADDY_FILE" <<CADDY
	handle {
		reverse_proxy relay:${WS_PORT}
	}
}
CADDY
  fi
fi

# ---------------------------------------------------------------
# Start
# ---------------------------------------------------------------

info "Starting services..."
echo ""

docker compose -f "$COMPOSE_FILE" up -d --pull always

# ---------------------------------------------------------------
# Summary
# ---------------------------------------------------------------

echo ""
echo "  ================================================================"
echo "   CLASP Relay is running"
echo "  ================================================================"
echo ""

if [ "$ENABLE_TLS" = true ]; then
  echo "  WebSocket:    wss://${DOMAIN}"
  [ "$ENABLE_AUTH" = true ] && echo "  Auth API:     https://${DOMAIN}/auth/"
  [ "$ENABLE_HEALTH" = true ] && echo "  Health:       https://${DOMAIN} (via Caddy)"
else
  echo "  WebSocket:    ws://${DOMAIN}:${WS_PORT}"
  [ "$ENABLE_AUTH" = true ] && echo "  Auth API:     http://${DOMAIN}:${AUTH_PORT}/auth/"
  [ "$ENABLE_HEALTH" = true ] && echo "  Health:       http://${DOMAIN}:${HEALTH_PORT}/healthz"
fi

[ "$ENABLE_MQTT" = true ] && echo "  MQTT:         ${DOMAIN}:${MQTT_PORT}"
[ "$ENABLE_OSC" = true ] && echo "  OSC:          ${DOMAIN}:${OSC_PORT} (UDP)"
[ "$ENABLE_QUIC" = true ] && echo "  QUIC:         ${DOMAIN}:${QUIC_PORT} (UDP)"
[ "$ENABLE_FEDERATION" = true ] && echo "  Federation:   ${FEDERATION_HUB} (as ${FEDERATION_ID})"
[ "$ENABLE_JOURNAL" = true ] && echo "  Journal:      ${JOURNAL_BACKEND}"
[ "$ENABLE_RULES" = true ] && echo "  Rules:        ${RULES_PATH}"
[ "$ENABLE_LENSES" = true ] && echo "  Lenses:       ${LENSES_PATH}"

if [ "$ENABLE_METRICS" = true ]; then
  if [ "$ENABLE_TLS" = true ]; then
    echo "  Metrics:      https://${DOMAIN}/metrics"
  else
    echo "  Metrics:      http://${DOMAIN}:${METRICS_PORT}/metrics"
  fi
fi

echo ""
if [ "$ENABLE_AUTH" = true ]; then
  echo "  Admin Token:  ${ADMIN_TOKEN}"
  echo "  Token File:   ${TOKEN_FILE}"
  echo ""
  echo "  Save your admin token. It will not be shown again."
fi

echo ""
echo "  ---- Management ----"
echo ""
echo "  View logs:     docker compose -f ${COMPOSE_FILE} logs -f"
echo "  Restart:       docker compose -f ${COMPOSE_FILE} restart"
echo "  Stop:          docker compose -f ${COMPOSE_FILE} down"
echo "  Reconfigure:   clasp-setup"
echo "  Uninstall:     docker compose -f ${COMPOSE_FILE} down -v && rm -rf /opt/clasp /var/lib/clasp /usr/local/bin/clasp-setup"
echo ""
echo "  ---- Config files ----"
echo ""
echo "  Compose:       ${COMPOSE_FILE}"
[ "$ENABLE_TLS" = true ] && echo "  Caddyfile:     ${CADDY_FILE}"
echo "  Data:          ${DATA_DIR}/"
[ "$ENABLE_RULES" = true ] && echo "  Rules:         ${DATA_DIR}/rules.json"
[ "$ENABLE_LENSES" = true ] && echo "  Lenses:        ${DATA_DIR}/lenses.json"
[ "$ENABLE_APP_CONFIG" = true ] && echo "  App config:    ${DATA_DIR}/app-config.json"
echo ""
echo "  ---- Documentation ----"
echo ""
echo "  Docs:          https://docs.clasp.to"
echo "  SDK:           npm install @clasp-to/core"
echo "  GitHub:        https://github.com/lumencanvas/clasp"
echo ""
